#!/bin/bash
# macOS PKG postinstall script
# Runs as root AFTER files are installed to /Applications/Kaitu.app

K2="/Applications/Kaitu.app/Contents/MacOS/k2"
NE_SYSEXT="/Applications/Kaitu.app/Contents/Library/SystemExtensions/io.kaitu.desktop.tunnel.systemextension"

# 0. Create CLI symlink so `k2` is available in terminal
if [ -x "$K2" ]; then
    ln -sf "$K2" /usr/local/bin/k2
fi

# 1. Install daemon service (NE mode: skip — NE profile installed by app at runtime)
if [ -d "$NE_SYSEXT" ]; then
    # NE mode: KaituTunnel.appex is present — Network Extension handles VPN,
    # no daemon service needed. The NE profile is installed by the app at runtime
    # via ensure_ne_installed() in Rust.
    echo "NE mode: skipping daemon service install (systemextension present)"
else
    # Legacy daemon mode: install k2 service
    if [ -x "$K2" ]; then
        "$K2" service install 2>&1 || true
    fi
fi

# 2. Change .app ownership to logged-in user so Tauri auto-updater can
#    replace the bundle without elevation (std::fs::rename succeeds).
#    Security: /Applications/ is already admin-group-writable, so any admin
#    user can already delete/replace Kaitu.app — chown adds no new attack surface.
CONSOLE_USER=$(stat -f "%Su" /dev/console)
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    chown -R "$CONSOLE_USER:admin" /Applications/Kaitu.app
fi

# 3. Launch the newly installed Kaitu app as the logged-in user
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    sudo -u "$CONSOLE_USER" open /Applications/Kaitu.app &
fi

exit 0
