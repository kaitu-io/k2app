#!/bin/bash
# macOS PKG preinstall script
# Runs as root BEFORE files are copied to /Applications/Kaitu.app

K2="/Applications/Kaitu.app/Contents/MacOS/k2"
KAITU_SERVICE="/Applications/Kaitu.app/Contents/MacOS/kaitu-service"

# 1. Quit the running Kaitu app and wait for it to exit (covers Kaitu + old kaitu-desktop)
if pgrep -f "Kaitu.app" >/dev/null 2>&1; then
    pkill -f "Kaitu.app" 2>/dev/null || true
    for i in $(seq 1 10); do
        pgrep -f "Kaitu.app" >/dev/null 2>&1 || break
        sleep 0.5
    done
    pkill -9 -f "Kaitu.app" 2>/dev/null || true
fi

# 2. Uninstall existing service via binary CLI (try both old and new binary names)
if [ -x "$K2" ]; then
    "$K2" service uninstall 2>&1 || true
fi
if [ -x "$KAITU_SERVICE" ]; then
    "$KAITU_SERVICE" service uninstall 2>&1 || true
fi

# 3. Clean up all known launchd service variants (legacy + current formats)
for PLIST in \
    /Library/LaunchDaemons/io.kaitu.k2.plist \
    /Library/LaunchDaemons/io.kaitu.service.plist \
    /Library/LaunchDaemons/com.kaitu.service.plist \
    /Library/LaunchDaemons/kaitu.plist; do
    if [ -f "$PLIST" ]; then
        launchctl unload "$PLIST" 2>/dev/null || true
        rm -f "$PLIST"
    fi
done

# 4. Kill orphaned daemon processes (launchd KeepAlive already removed by step 3)
#    Only needed if a daemon was started outside launchd or launchctl unload didn't SIGTERM it
pkill -x kaitu-service 2>/dev/null || true
pkill -x k2 2>/dev/null || true
sleep 1
pkill -9 -x kaitu-service 2>/dev/null || true
pkill -9 -x k2 2>/dev/null || true

# 5. Wait for cleanup
sleep 1

# 6. Clear WebKit HTTP cache (prevents stale webapp assets after upgrade)
#    Must run AFTER app is killed (step 1) to avoid file locks.
#    Preserves: ~/Library/Application Support/io.kaitu.desktop/ (update-channel, pre-beta-log-level)
#    Preserves: ~/Library/WebKit/io.kaitu.desktop/ (LocalStorage has encrypted auth tokens)
CONSOLE_USER=$(stat -f "%Su" /dev/console 2>/dev/null)
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ]; then
    USER_HOME=$(dscl . -read /Users/"$CONSOLE_USER" NFSHomeDirectory 2>/dev/null | awk '{print $2}')
    if [ -n "$USER_HOME" ] && [ -d "$USER_HOME/Library" ]; then
        rm -rf "$USER_HOME/Library/Caches/io.kaitu.desktop" 2>/dev/null || true
    fi
fi

exit 0
