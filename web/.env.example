# Payload CMS — connects to shared dev-postgres container (managed by user-level postgres-dev MCP)
DATABASE_URL=postgres://payload:payload@localhost:5432/kaitu_cms
PAYLOAD_SECRET=replace-me-with-a-random-32-byte-hex-string

# Translator (OpenRouter)
TRANSLATOR_BASE_URL=https://openrouter.ai/api
TRANSLATOR_API_KEY=sk-or-v1-xxx
TRANSLATOR_MODEL=google/gemini-2.5-flash

# Center API SSO bridge
CENTER_API_URL=https://k2.52j.me

# Media storage (S3 + CloudFront)
S3_BUCKET=kaitu-cms-media
S3_REGION=ap-northeast-1
S3_ACCESS_KEY_ID=AKIA...
S3_SECRET_ACCESS_KEY=...
CDN_URL=https://media.kaitu.io

# Sentry (error monitoring + session replay)
# DSN is public — bundled into client JS. Empty value = SDK no-ops cleanly.
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only — used by withSentryConfig to upload source maps.
SENTRY_ORG=anc-3w
SENTRY_PROJECT=javascript-nextjs
SENTRY_AUTH_TOKEN=

# Brand baked at build time: kaitu (default) | overleap. Phase 2 dual-deployment.
NEXT_PUBLIC_BRAND=kaitu
