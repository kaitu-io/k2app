#!/bin/sh
# Kaitu Desktop Client Installer
# Linux: tar.gz + k2 daemon + systemd service
# macOS: PKG installer
#
# Usage: curl -fsSL https://kaitu.io/i/k2 | sudo bash
set -e

CDN_PRIMARY="https://dl.kaitu.io/kaitu"
CDN_FALLBACK="https://d13jc1jqzlg4yt.cloudfront.net/kaitu"
MANIFEST=""

# --- Helpers ---

info()  { echo "[kaitu] $*"; }
error() { echo "[kaitu] ERROR: $*" >&2; exit 1; }

fetch() {
    url="$1"
    if command -v curl >/dev/null 2>&1; then
        curl -fsSL "$url"
    elif command -v wget >/dev/null 2>&1; then
        wget -qO- "$url"
    else
        echo "Error: curl or wget required" >&2
        exit 1
    fi
}

download() {
    url="$1"; dest="$2"
    if command -v curl >/dev/null 2>&1; then
        curl -fSL -o "$dest" "$url"
    else
        wget -qO "$dest" "$url"
    fi
}

download_with_fallback() {
    dest="$1"; primary="$2"; fallback="$3"
    if ! download "$primary" "$dest" 2>/dev/null; then
        if ! download "$fallback" "$dest" 2>/dev/null; then
            error "Failed to download from both CDN endpoints"
        fi
    fi
}

# Compute SHA-256 of a file using whichever tool is available.
# Prints the 64-char lowercase hex digest to stdout, or empty on failure.
sha256_of() {
    file="$1"
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$file" 2>/dev/null | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$file" 2>/dev/null | awk '{print $1}'
    elif command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha256 "$file" 2>/dev/null | awk '{print $NF}'
    else
        echo ""
    fi
}

# Verify $file matches the digest recorded in $sha_file.
# $sha_file is in standard `sha256sum` format: `<64 hex>  <basename>`; we
# only consume the first field so the basename need not match exactly.
# Errors out with a clear message on any mismatch or tooling gap — this
# is the only supply-chain gate between the CDN and extraction, so a
# soft failure here would defeat the purpose.
verify_sha256() {
    file="$1"; sha_file="$2"
    expected=$(awk '{print $1; exit}' "$sha_file" 2>/dev/null)
    case "$expected" in
        *[!0-9a-fA-F]*|"")
            error "Checksum file is malformed (${sha_file})"
            ;;
    esac
    actual=$(sha256_of "$file")
    if [ -z "$actual" ]; then
        error "No sha256 tool available (need sha256sum, shasum, or openssl)"
    fi
    # Normalize both sides to lowercase for comparison.
    expected_lc=$(printf '%s' "$expected" | tr '[:upper:]' '[:lower:]')
    actual_lc=$(printf '%s' "$actual" | tr '[:upper:]' '[:lower:]')
    if [ "$expected_lc" != "$actual_lc" ]; then
        error "Checksum mismatch for $(basename "$file"): expected ${expected_lc}, got ${actual_lc}"
    fi
}

detect_platform() {
    OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
    ARCH="$(uname -m)"
    case "$OS" in
        linux)  OS="linux" ;;
        darwin) OS="darwin" ;;
        *)      error "Unsupported OS: $OS. Use https://kaitu.io/install for Windows." ;;
    esac
    case "$ARCH" in
        x86_64|amd64)  ARCH="amd64" ;;
        aarch64|arm64) ARCH="arm64" ;;
        *)             error "Unsupported architecture: $ARCH" ;;
    esac
}

get_latest_version() {
    channel="beta"
    for arg in "$@"; do
        case "$arg" in
            --channel=*) channel="${arg#*=}" ;;
        esac
    done

    manifest_path="desktop"
    if [ "$channel" = "beta" ]; then
        manifest_path="desktop/beta"
    fi

    MANIFEST=$(fetch "${CDN_PRIMARY}/${manifest_path}/cloudfront.latest.json" 2>/dev/null || true)
    VERSION=$(echo "$MANIFEST" | grep '"version"' | head -1 | sed 's/.*"version" *: *"//;s/".*//' || true)

    if [ -z "$VERSION" ]; then
        MANIFEST=$(fetch "${CDN_FALLBACK}/${manifest_path}/cloudfront.latest.json" 2>/dev/null || true)
        VERSION=$(echo "$MANIFEST" | grep '"version"' | head -1 | sed 's/.*"version" *: *"//;s/".*//' || true)
    fi

    if [ -z "$VERSION" ]; then
        error "Could not determine latest version"
    fi
}

# --- Linux ---
#
# Starting with v0.4.2 the Linux desktop ships as a single Go binary with
# the React webapp embedded (no Tauri, no webkit2gtk). Users access the UI
# in their browser at http://127.0.0.1:1777 — this shim just downloads the
# tarball and defers to the install.sh that ships inside it, so the install
# logic lives in exactly one place (packaging/linux/install.sh).

has_systemd() {
    command -v systemctl >/dev/null 2>&1 && [ -d /run/systemd/system ]
}

# Remove a legacy pre-v0.4.2 install from the old Tauri-based shim, if any.
# That shim wrote /opt/kaitu/* and registered /etc/systemd/system/k2.service;
# leaving it in place would fight the new kaitu.service for port 1777.
cleanup_legacy_install() {
    if [ -f /etc/systemd/system/k2.service ] || [ -d /opt/kaitu ]; then
        info "Removing legacy pre-v0.4.2 install (/opt/kaitu, k2.service)..."
        systemctl stop k2.service 2>/dev/null || true
        systemctl disable k2.service 2>/dev/null || true
        rm -f /etc/systemd/system/k2.service
        rm -rf /opt/kaitu
        rm -f /usr/local/bin/kaitu-uninstall
        systemctl daemon-reload 2>/dev/null || true
    fi
}

install_linux() {
    if [ "$ARCH" != "amd64" ]; then
        error "Linux currently only supports amd64."
    fi

    if ! has_systemd; then
        error "systemd not detected. Kaitu Linux requires systemd."
    fi

    cleanup_legacy_install

    TARBALL="Kaitu_${VERSION}_linux_amd64.tar.gz"
    SHA_FILE="${TARBALL}.sha256"
    TMP_DIR="$(mktemp -d -t kaitu-install.XXXXXX)"
    trap 'rm -rf "$TMP_DIR"' EXIT

    info "Downloading ${TARBALL}..."
    download_with_fallback "${TMP_DIR}/${TARBALL}" \
        "${CDN_PRIMARY}/desktop/${VERSION}/${TARBALL}" \
        "${CDN_FALLBACK}/desktop/${VERSION}/${TARBALL}"

    info "Downloading ${SHA_FILE}..."
    download_with_fallback "${TMP_DIR}/${SHA_FILE}" \
        "${CDN_PRIMARY}/desktop/${VERSION}/${SHA_FILE}" \
        "${CDN_FALLBACK}/desktop/${VERSION}/${SHA_FILE}"

    info "Verifying SHA-256 checksum..."
    verify_sha256 "${TMP_DIR}/${TARBALL}" "${TMP_DIR}/${SHA_FILE}"

    info "Extracting..."
    tar xzf "${TMP_DIR}/${TARBALL}" -C "$TMP_DIR"

    # The tarball ships k2 + install.sh + uninstall.sh + kaitu.service at
    # the top level. install.sh handles stop-on-upgrade, binary placement,
    # systemd registration, start, and xdg-open of the webui.
    if [ ! -x "${TMP_DIR}/install.sh" ]; then
        error "install.sh missing from tarball — release payload is incomplete."
    fi

    info "Running install.sh from tarball..."
    (cd "$TMP_DIR" && ./install.sh)
}

# --- macOS ---

install_macos() {
    info "Downloading Kaitu PKG v${VERSION}..."
    TMP_PKG="/tmp/Kaitu_${VERSION}_universal.pkg"
    download_with_fallback "$TMP_PKG" \
        "${CDN_PRIMARY}/desktop/${VERSION}/Kaitu_${VERSION}_universal.pkg" \
        "${CDN_FALLBACK}/desktop/${VERSION}/Kaitu_${VERSION}_universal.pkg"

    info "Installing Kaitu..."
    installer -pkg "$TMP_PKG" -target /
    rm -f "$TMP_PKG"

    info ""
    info "=== Installation complete ==="
    info "  Launch Kaitu from Applications or Spotlight."
}

# --- Main ---

main() {
    if [ "$(id -u)" -ne 0 ]; then
        error "Run with sudo: curl -fsSL https://kaitu.io/i/k2 | sudo bash"
    fi

    detect_platform
    get_latest_version "$@"

    info "Installing Kaitu v${VERSION} (${OS}/${ARCH})..."

    case "$OS" in
        linux)  install_linux ;;
        darwin) install_macos ;;
    esac
}

main "$@"
