    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.18",
    "express-rate-limit": "^8.2.2",
    "fast-uri": "^3.1.2",
    "ip-address": "^10.1.1",
    "path-to-regexp": "^8.4.0",
    "postcss": "^8.5.10",
    "rollup": "^4.59.0"
