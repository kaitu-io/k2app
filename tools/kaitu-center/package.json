{
  "name": "kaitu-center",
  "version": "0.5.0",
  "description": "Kaitu Center API tools — MCP server (Claude Code) + OpenClaw plugin",
  "type": "module",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "openclaw": {
    "extensions": ["./src/openclaw.ts"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
